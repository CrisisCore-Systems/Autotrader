# Text files - enforce LF to reduce cross-platform diff noise
*.py text eol=lf
*.md text eol=lf
*.json text eol=lf
reports/crypto/live_staging_status.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.toml text eol=lf

# Binary files - mark explicitly to avoid incorrect diffs
*.db binary
*.sqlite binary
*.sqlite3 binary
data/raw/** filter=lfs diff=lfs merge=lfs -text
data/processed/** filter=lfs diff=lfs merge=lfs -text
artifacts/models/** filter=lfs diff=lfs merge=lfs -text
